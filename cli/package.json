{
  "name": "agentrune",
  "version": "0.3.1",
  "description": "AgentRune CLI — AI agent mission control + AgentLore MCP server",
  "type": "module",
  "bin": {
    "agentrune": "dist/bin.js"
  },
  "files": [
    "dist",
    "dev-daemon.sh",
    "release-daemon.sh",
    "safe-restart.sh",
    "watchdog-common.sh"
  ],
  "scripts": {
    "dev": "tsx watch src/bin.ts -- start -p 3457 -f",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "node-pty": "^1.0.0",
    "open": "^11.0.0",
    "opencc-js": "^1.0.5",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
